---
import { Icon } from "astro-icon/components";
import Container from "./Container.astro";
import SectionTitle from "./SectionTitle.astro";
---

<section
  id="processo"
  class="py-24 bg-primary text-white relative overflow-hidden"
>
  <Container class="relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="reveal">
        <div class="mb-12">
          <span
            class="text-white font-semibold uppercase tracking-wider text-sm mb-2 block"
          >
            Metodologia
          </span>
          <h2 class="text-3xl md:text-5xl font-bold text-white leading-tight">
            Produção de conteúdo digital em escala
          </h2>
        </div>

        <p class="text-primary-100 text-lg mb-8 text-white/80">
          Empresas que desejam crescer no ambiente digital precisam produzir
          conteúdo profissional de forma consistente. A produção de podcasts e
          vídeos permite fortalecer sua comunicação e autoridade.
        </p>

        <div class="space-y-6">
          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center shrink-0 border border-white/20"
            >
              <Icon name="ph:calendar-check" class="w-6 h-6 text-white" />
            </div>
            <div>
              <h3 class="font-bold text-lg mb-1 mt-1">Sessão Única</h3>
              <p class="text-white/70 text-sm">
                Aqui você grava podcasts corporativos, entrevistas e vídeos em
                um único dia de produção.
              </p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center shrink-0 border border-white/20"
            >
              <Icon name="ph:fast-forward" class="w-6 h-6 text-white" />
            </div>
            <div>
              <h3 class="font-bold text-lg mb-1 mt-1">Processo Eficiente</h3>
              <p class="text-white/70 text-sm">
                Desenhado para ser profissional e escalar a geração de conteúdo
                em diversas plataformas.
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="reveal">
        <div
          class="bg-white/5 backdrop-blur-md rounded-3xl p-8 border border-white/10 shadow-2xl relative"
        >
          <Icon
            name="ph:quotes"
            class="absolute top-6 right-6 w-12 h-12 text-white/10"
          />
          <h4 class="text-xl font-bold mb-6 text-white">
            Benefícios do nosso modelo
          </h4>

          <div
            class="space-y-8 relative before:absolute before:inset-y-0 before:left-3.5 before:w-0.5 before:bg-white/20"
          >
            <div class="relative flex gap-6">
              <div
                class="w-7 h-7 rounded-full bg-secondary flex items-center justify-center shadow-lg ring-4 ring-primary z-10 shrink-0"
              >
                <span class="text-xs font-bold">1</span>
              </div>
              <div>
                <h5 class="font-bold text-white">Planejamento</h5>
                <p class="text-sm text-white/70 mt-1">
                  Estratégias de conteúdo para máxima conversão.
                </p>
              </div>
            </div>

            <div class="relative flex gap-6">
              <div
                class="w-7 h-7 rounded-full bg-secondary flex items-center justify-center shadow-lg ring-4 ring-primary z-10 shrink-0"
              >
                <span class="text-xs font-bold">2</span>
              </div>
              <div>
                <h5 class="font-bold text-white">Gravação</h5>
                <p class="text-sm text-white/70 mt-1">
                  Sessões otimizadas no estúdio profissional.
                </p>
              </div>
            </div>

            <div class="relative flex gap-6">
              <div
                class="w-7 h-7 rounded-full bg-secondary flex items-center justify-center shadow-lg ring-4 ring-primary z-10 shrink-0"
              >
                <span class="text-xs font-bold">3</span>
              </div>
              <div>
                <h5 class="font-bold text-white">Multiplicação</h5>
                <p class="text-sm text-white/70 mt-1">
                  Recortes e edição para todas as redes sociais.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
