---
import { Image } from "astro:assets";
import Container from "./Container.astro";
import SectionTitle from "./SectionTitle.astro";

import bahia from "../assets/clients/bahia.png";
import fam from "../assets/clients/fam.png";
import hagari from "../assets/clients/hagari-cast.png";
import neos from "../assets/clients/neos.png";
import pausa from "../assets/clients/projeto-pausa.png";
import soham from "../assets/clients/soham-cast.png";

const clientLogos = [
  { src: bahia, alt: "Bahia" },
  { src: fam, alt: "FAM" },
  { src: hagari, alt: "Hagari Cast" },
  { src: neos, alt: "Neos" },
  { src: pausa, alt: "Projeto Pausa" },
  { src: soham, alt: "Soham Cast" },
];

// Duplicar para efeito infinito
const marqueeItems = [
  ...clientLogos,
  ...clientLogos,
  ...clientLogos,
  ...clientLogos,
];
---

<section
  id="projetos"
  class="py-24 bg-white relative overflow-hidden border-t border-gray-100"
>
  <Container>
    <div class="text-center md:max-w-2xl mx-auto mb-16 reveal">
      <SectionTitle
        title="Projetos e Parcerias"
        subtitle="Confiança"
        alignment="center"
      />
      <p class="text-gray-600">
        Colaboramos com empresas, especialistas e marcas que buscam desenvolver
        sua presença digital com mais estrutura e profissionalismo.
      </p>
    </div>

    <div
      class="relative flex overflow-x-hidden reveal"
      style="transition-delay: 50ms;"
    >
      <div
        class="py-8 flex gap-4 animate-marquee whitespace-nowrap items-center"
      >
        {
          marqueeItems.map((client) => (
            <div class="shrink-0 group">
              <Image
                src={client.src}
                alt={client.alt}
                height={200}
                class="h-48 w-auto object-contain transition-all duration-500 rounded-2xl"
              />
            </div>
          ))
        }
      </div>
    </div>
  </Container>
  <style>
    .animate-marquee {
      animation: marquee 30s linear infinite;
    }
    .animate-marquee:hover {
      animation-play-state: paused;
    }
    @keyframes marquee {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(-50%);
      }
    }
  </style>
</section>
