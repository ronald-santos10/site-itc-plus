---
import { Icon } from 'astro-icon/components';
import Container from './Container.astro';
import Button from './Button.astro';
import LeadForm from './LeadForm.astro';
---

<section id="contato" class="py-32 relative overflow-hidden">
	<div class="absolute inset-0 bg-primary z-0"></div>
	<div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff12_1px,transparent_1px),linear-gradient(to_bottom,#ffffff12_1px,transparent_1px)] bg-size-[24px_24px] z-0"></div>
	<div class="absolute right-0 bottom-0 w-[500px] h-[500px] bg-secondary opacity-30 blur-[150px] rounded-full translate-x-1/4 translate-y-1/4 z-0 pointer-events-none"></div>
	
	<Container class="relative z-10">
		<div class="grid lg:grid-cols-2 gap-16 items-center">
			<div class="reveal text-left">
				<h2 class="text-4xl lg:text-6xl font-black mb-8 leading-tight tracking-tight text-white">
					Vamos estruturar o digital da sua empresa?
				</h2>
				
				<p class="text-xl text-primary-100 mb-12 text-white/90 font-light leading-relaxed max-w-2xl">
					Receba um diagnóstico gratuito e entenda o que precisa ser ajustado para transformar sua presença digital em geração de novos clientes.
				</p>
				
				<div class="flex flex-col sm:flex-row gap-6 mb-12 lg:mb-0">
					<div class="flex items-center gap-4 text-white/80">
						<div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center">
							<Icon name="ph:check-circle-fill" class="w-6 h-6 text-secondary" />
						</div>
						<span class="font-medium text-sm">Diagnóstico Gratuito</span>
					</div>
					<div class="flex items-center gap-4 text-white/80">
						<div class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center">
							<Icon name="ph:check-circle-fill" class="w-6 h-6 text-secondary" />
						</div>
						<span class="font-medium text-sm">Estratégia Customizada</span>
					</div>
				</div>
			</div>

			<div class="reveal">
				<LeadForm />
			</div>
		</div>
	</Container>
</section>
