---
import { Icon } from "astro-icon/components";
import Container from "./Container.astro";
import SectionTitle from "./SectionTitle.astro";

const structure = [
  {
    title: "Conteúdo profissional",
    description:
      "Produção audiovisual profissional, vídeos institucionais, vídeos para redes sociais e podcasts corporativos que fortalecem a comunicação da empresa.",
    icon: "ph:video-camera",
  },
  {
    title: "Plataformas digitais",
    description:
      "Desenvolvimento de sites institucionais, landing pages, plataformas digitais e aplicativos que funcionam como base da presença online da empresa.",
    icon: "ph:devices",
  },
  {
    title: "Autoridade digital",
    description:
      "Estratégias de posicionamento e comunicação digital que ajudam empresas a construir autoridade no ambiente online.",
    icon: "ph:star",
  },
  {
    title: "Crescimento digital",
    description:
      "Estratégias de SEO, produção de conteúdo e presença digital que ampliam visibilidade e alcance online.",
    icon: "ph:trend-up",
  },
];
---

<section id="estrutura" class="py-24 bg-white relative">
  <Container>
    <div class="grid xl:grid-cols-2 gap-16 items-center">
      <!-- BLOCO 5 - Texto -->
      <div class="reveal">
        <SectionTitle
          title="O problema não é estar no digital. É não ter estrutura."
          subtitle="Posicionamento digital"
        />

        <div class="prose text-gray-600 prose-lg">
          <p class="mb-6">
            Muitas empresas já tentaram redes sociais, anúncios ou produção de conteúdo. Mas sem estratégia e qualidade, o digital não gera resultado. 
          </p>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3">
              <Icon
                name="ph:warning-circle"
                class="w-6 h-6 text-red-500 shrink-0 mt-1"
              />
              <span class="text-gray-700">Perfis sem posicionamento estratégico.</span>
            </li>
            <li class="flex items-start gap-3">
              <Icon
                name="ph:warning-circle"
                class="w-6 h-6 text-red-500 shrink-0 mt-1"
              />
              <span class="text-gray-700">Sites que não convertem visitantes em clientes.</span>
            </li>
            <li class="flex items-start gap-3">
              <Icon
                name="ph:warning-circle"
                class="w-6 h-6 text-red-500 shrink-0 mt-1"
              />
              <span class="text-gray-700">Conteúdos que não geram autoridade real.</span>
            </li>
          </ul>

          <p class="font-medium text-gray-900 border-l-4 border-primary pl-4 py-1 italic bg-primary/5 rounded-r-lg">
            O resultado é investimento sem retorno e uma presença digital fraca.
          </p>
        </div>
      </div>

      <!-- BLOCO 6 - Features/Estrutura -->
      <div class="grid sm:grid-cols-2 gap-6 relative">
        <div class="absolute -inset-4 bg-gray-50 rounded-3xl -z-10 reveal">
        </div>
        {
          structure.map((item, index) => (
            <div
              class="reveal bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-lg hover:border-primary/20 transition-all duration-300 group"
              style={`transition-delay: ${index * 150}ms`}
            >
              <div class="w-12 h-12 bg-gray-50 rounded-xl flex items-center justify-center mb-6 group-hover:bg-primary/10 transition-colors duration-300">
                <Icon name={item.icon} class="w-6 h-6 text-primary" />
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-3">{item.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">
                {item.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </Container>
</section>
