---
import { Icon } from "astro-icon/components";
import Container from "./Container.astro";
import SectionTitle from "./SectionTitle.astro";

const solutions = [
  {
    title: "Estratégia de Presença Digital",
    desc: "Planejamento completo para empresas que desejam construir autoridade e crescer no ambiente digital.",
    icon: "ph:strategy",
  },
  {
    title: "Produção Audiovisual",
    desc: "Criação de vídeos profissionais, institucionais e conteúdos de alto impacto para sua marca.",
    icon: "ph:video-camera",
  },
  {
    title: "Podcasts Corporativos",
    desc: "Estrutura completa e profissional para gravação de podcasts e videocasts focados em autoridade.",
    icon: "ph:microphone-stage",
  },
  {
    title: "Gestão de Redes Sociais para Empresas",
    desc: "Gestão completa com foco em posicionamento estratégico e engajamento da audiência certa para o seu negócio.",
    icon: "ph:share-network",
  },
  {
    title: "Criação de Sites Profissionais",
    desc: "Desenvolvimento e otimização de sites institucionais e landing pages focados em conversão e experiência do usuário.",
    icon: "ph:browser",
  },
  {
    title: "Geração de Leads e Tráfego Pago",
    desc: "Gestão de anúncios especializados em plataformas como Google e Meta para geração de leads qualificados.",
    icon: "ph:chart-line-up",
  },
];
---

<section
  id="servicos"
  class="py-24 bg-gray-50 relative border-t border-gray-100"
>
  <Container>
    <div class="text-center md:max-w-2xl mx-auto mb-16 reveal">
      <SectionTitle
        title="Tudo o que sua empresa precisa para crescer no digital"
        subtitle="Nossos Serviços"
        alignment="center"
      />
      <p class="text-gray-600">
        Combinamos as melhores ferramentas e estratégias para garantir que sua empresa tenha uma presença digital de alto nível.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        solutions.map((item, i) => (
          <div
            class="reveal bg-white rounded-3xl p-6 md:p-8 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-transparent hover:border-gray-200 group"
            style={`transition-delay: ${i * 100}ms`}
          >
            <div class="w-14 h-14 bg-linear-to-br from-primary/10 to-secondary/10 rounded-2xl flex items-center justify-center mb-8 text-primary group-hover:scale-110 transition-transform duration-300">
              <Icon name={item.icon} class="w-7 h-7" />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-4">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))
      }
    </div>
  </Container>
</section>
