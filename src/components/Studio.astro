---
import { Icon } from 'astro-icon/components';
import Container from './Container.astro';
import SectionTitle from './SectionTitle.astro';

const structureList = [
	"Gravação multicâmera 4K",
	"Iluminação profissional para vídeo",
	"Equipamentos de áudio de alta qualidade",
	"Ambiente confortável e preparado",
	"Estrutura para gravações corporativas"
];
---

<section id="estudio" class="py-24 bg-white relative overflow-hidden">
	<div class="absolute right-0 top-0 w-1/3 h-full bg-primary/5 -skew-x-12 -z-10 translate-x-1/2"></div>
	
	<Container>
		<div class="md:max-w-2xl mx-auto mb-16 reveal">
			<SectionTitle 
				title="Estúdio de podcast e produção audiovisual" 
				subtitle="Estrutura em Pinheiros"
				alignment="center"
			/>
		</div>
		<div class="flex flex-col-reverse lg:flex-row items-center gap-16">
			<div class="lg:w-1/2 relative reveal w-full">
				<div class="grid grid-cols-2 gap-4">
					<div class="space-y-4 translate-y-8">
						<img src="https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?auto=format&fit=crop&w=600&q=80" alt="Podcast 1" class="w-full h-32 md:h-48 object-cover rounded-2xl shadow-lg" loading="lazy" />
						<img src="https://images.unsplash.com/photo-1581362036044-c76cebd1262d?auto=format&fit=crop&w=600&q=80" alt="Camera Setup" class="w-full h-48 md:h-64 object-cover rounded-2xl shadow-lg" loading="lazy" />
					</div>
					<div class="space-y-4">
						<img src="https://images.unsplash.com/photo-1620603704981-2292a1885f83?auto=format&fit=crop&w=600&q=80" alt="Audio equipment" class="w-full h-48 md:h-64 object-cover rounded-2xl shadow-lg" loading="lazy" />
						<img src="https://images.unsplash.com/photo-1478737270239-2f02b77fc618?auto=format&fit=crop&w=600&q=80" alt="Studio Lighting" class="w-full h-32 md:h-48 object-cover rounded-2xl shadow-lg" loading="lazy" />
					</div>
				</div>
			</div>
			
			<div class="lg:w-1/2 reveal">
				<div class="prose text-gray-600 prose-lg max-w-none">
					<p class="mb-4">
						O estúdio da ITC+ foi desenvolvido para oferecer uma estrutura profissional de produção audiovisual para empresas e especialistas.
					</p>
					<p class="mb-8">
						Localizado em Pinheiros, São Paulo, o estúdio permite realizar gravações de podcasts corporativos, videocasts, entrevistas e vídeos institucionais em ambiente totalmente preparado para conteúdo digital.
					</p>
				</div>
				
				<div class="bg-gray-50 rounded-2xl border border-gray-100 p-6 md:p-8 shadow-sm">
					<h4 class="font-bold text-gray-900 text-lg mb-6 flex items-center gap-2">
						<Icon name="ph:speaker-high" class="w-6 h-6 text-primary" />
						Estrutura do estúdio
					</h4>
					
					<ul class="space-y-4">
						{structureList.map(item => (
							<li class="flex items-center gap-3">
								<div class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
									<Icon name="ph:check" class="w-4 h-4 text-primary" />
								</div>
								<span class="text-gray-700 font-medium">{item}</span>
							</li>
						))}
					</ul>
				</div>
			</div>
		</div>
	</Container>
</section>
