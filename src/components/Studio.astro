---
import { Icon } from 'astro-icon/components';
import Container from './Container.astro';
import SectionTitle from './SectionTitle.astro';

const structureList = [
	"Gravação multicâmera 4K",
	"Iluminação profissional para vídeo",
	"Equipamentos de áudio de alta qualidade",
	"Ambiente confortável e preparado",
	"Estrutura para gravações corporativas"
];

import studio1 from "../assets/image-1.webp";
import studio2 from "../assets/image-2.webp";
import studio3 from "../assets/image-3.webp";
import studio4 from "../assets/image-4.webp";
import { Image } from 'astro:assets';

---

<section id="estudio" class="py-24 bg-white relative overflow-hidden">
	<div class="absolute right-0 top-0 w-1/3 h-full bg-primary/5 -skew-x-12 -z-10 translate-x-1/2"></div>
	
	<Container>
		<div class="md:max-w-2xl mx-auto mb-16 reveal">
			<SectionTitle 
				title="Estrutura profissional e experiência real" 
				subtitle="Prova e autoridade"
				alignment="center"
			/>
		</div>
		<div class="flex flex-col-reverse lg:flex-row items-center gap-16">
			<div class="lg:w-1/2 relative reveal w-full">
				<div class="grid grid-cols-2 gap-4">
					<div class="space-y-4 translate-y-8">
						<Image src={studio1} alt="Podcast Studio" class="w-full h-32 md:h-48 object-cover rounded-2xl shadow-lg" loading="lazy" />
						<Image src={studio2} alt="Camera Setup" class="w-full h-48 md:h-64 object-cover rounded-2xl shadow-lg" loading="lazy" />
					</div>
					<div class="space-y-4">
						<Image src={studio3} alt="Audio Console" class="w-full h-48 md:h-64 object-cover rounded-2xl shadow-lg" loading="lazy" />
						<Image src={studio4} alt="Microfone Condensador" class="w-full h-32 md:h-48 object-cover rounded-2xl shadow-lg" loading="lazy" />
					</div>
				</div>
			</div>
			
			<div class="lg:w-1/2 reveal">
				<div class="prose text-gray-600 prose-lg max-w-none">
					<p class="mb-4">
						A ITC+ atua com empresas que buscam mais do que presença digital. Buscam posicionamento, autoridade e crescimento. 
					</p>
					<p class="mb-8">
						Trabalhamos com produção audiovisual profissional, estrutura de estúdio e estratégias aplicadas na prática para transformar sua empresa em referência.
					</p>
				</div>
				
				<div class="bg-gray-50 rounded-2xl border border-gray-100 p-6 md:p-8 shadow-sm">
					<h4 class="font-bold text-gray-900 text-lg mb-6 flex items-center gap-2">
						<Icon name="ph:speaker-high" class="w-6 h-6 text-primary" />
						Estrutura do estúdio
					</h4>
					
					<ul class="space-y-4">
						{structureList.map(item => (
							<li class="flex items-center gap-3">
								<div class="w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
									<Icon name="ph:check" class="w-4 h-4 text-primary" />
								</div>
								<span class="text-gray-700 font-medium">{item}</span>
							</li>
						))}
					</ul>
				</div>
			</div>
		</div>
	</Container>
</section>
