---
import { Icon } from 'astro-icon/components';
import Container from './Container.astro';
import SectionTitle from './SectionTitle.astro';
---

<section id="sobre" class="py-24 bg-gray-50 border-t border-gray-100">
	<Container>
		<div class="grid xl:grid-cols-2 gap-16 items-center">
			
			<div class="order-2 md:order-1 reveal">
				<div class="relative rounded-3xl overflow-hidden shadow-xl aspect-square md:aspect-auto md:h-[500px]">
					<img 
						src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?auto=format&fit=crop&w=800&q=80" 
						alt="Equipe ITC+" 
						class="w-full h-full object-cover"
						loading="lazy"
					/>
					<div class="absolute inset-0 bg-primary/20 mix-blend-multiply"></div>
				</div>
			</div>
			
			<div class="order-1 md:order-2 reveal">
				<SectionTitle 
					title="Sobre a ITC+" 
					subtitle="Especialistas"
				/>
				
				<div class="prose prose-lg text-gray-600 mb-8">
					<p>
						A ITC+ é uma empresa especializada em produção audiovisual, estúdio de podcast e desenvolvimento de plataformas digitais para empresas.
					</p>
					<p>
						Nosso trabalho integra <strong>conteúdo, tecnologia e estratégia digital</strong> para ajudar empresas a desenvolver uma presença online completa e altamente profissional.
					</p>
					<p>
						Atuamos na produção de vídeos e podcasts corporativos, unindo essas mídias com o desenvolvimento de sites e aplicativos para consolidar e ampliar seus resultados de marketing.
					</p>
				</div>
				
				<ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
					<li class="flex items-center gap-2 bg-white rounded-xl p-3 shadow-sm border border-gray-100">
						<Icon name="ph:check-circle" class="w-5 h-5 text-secondary" />
						<span class="font-medium text-gray-900 text-sm">Produção Audiovisual</span>
					</li>
					<li class="flex items-center gap-2 bg-white rounded-xl p-3 shadow-sm border border-gray-100">
						<Icon name="ph:check-circle" class="w-5 h-5 text-secondary" />
						<span class="font-medium text-gray-900 text-sm">Estúdio de Podcast</span>
					</li>
					<li class="flex items-center gap-2 bg-white rounded-xl p-3 shadow-sm border border-gray-100">
						<Icon name="ph:check-circle" class="w-5 h-5 text-secondary" />
						<span class="font-medium text-gray-900 text-sm">Desenvolvimento Web</span>
					</li>
					<li class="flex items-center gap-2 bg-white rounded-xl p-3 shadow-sm border border-gray-100">
						<Icon name="ph:check-circle" class="w-5 h-5 text-secondary" />
						<span class="font-medium text-gray-900 text-sm">Estratégias de Crescimento</span>
					</li>
				</ul>
			</div>

		</div>
	</Container>
</section>
