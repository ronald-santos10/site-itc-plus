---
import { Icon } from 'astro-icon/components';

interface Props {
	href?: string;
	variant?: 'primary' | 'secondary' | 'outline' | 'white';
	size?: 'sm' | 'md' | 'lg';
	icon?: string;
	class?: string;
	[x: string]: any;
}

const { 
	href, 
	variant = 'primary', 
	size = 'md', 
	icon, 
	class: className = '', 
	...rest 
} = Astro.props;

// Determine if we should add inline-flex (only if no other display class is present)
const hasDisplayClass = /\b(hidden|block|inline-block|flex|inline-flex|grid|inline-grid|table|inline-table|contents|list-item)\b/.test(className);
const displayClass = hasDisplayClass ? '' : 'inline-flex';

const baseStyles = "items-center justify-center gap-2 font-medium rounded-full transition-all duration-300 hover:-translate-y-1 active:scale-95 shadow-sm hover:shadow-md";

const variants = {
	primary: "bg-gradient-btn text-white shadow-primary/20",
	secondary: "bg-secondary text-white hover:opacity-90 shadow-secondary/20",
	outline: "bg-transparent border border-gray-200 text-gray-900 hover:bg-gray-50",
	white: "bg-white text-primary hover:bg-gray-50 shadow-white/10"
};

const sizes = {
	sm: "px-5 py-2 text-sm",
	md: "px-8 py-3.5 text-base text-sm md:text-base",
	lg: "px-10 py-5 text-lg font-bold"
};

const Tag = href ? 'a' : 'button';
---

<Tag 
	href={href} 
	class:list={[displayClass, baseStyles, variants[variant], sizes[size], className]}
	{...rest}
>
	<slot />
	{icon && <Icon name={icon} class:list={[
		size === 'sm' ? 'w-4 h-4' : size === 'lg' ? 'w-6 h-6' : 'w-5 h-5'
	]} />}
</Tag>
