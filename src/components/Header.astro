---
import Container from "./Container.astro";
import Button from "./Button.astro";
import { Image } from "astro:assets";

import logo from "../assets/logo-itc.svg";
---

<header
  id="main-header"
  class="fixed w-full top-0 left-0 bg-white/80 backdrop-blur-md z-50 border-b border-gray-100 transition-all duration-300"
>
  <Container class="flex items-center justify-between py-4">
    <a href="#" class="text-2xl font-bold tracking-tighter text-gray-900 group">
      <Image src={logo} alt="Logo ITC+" width="100" height="100" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden xl:flex items-center gap-8">
      <a
        href="#estrutura"
        class="text-sm font-medium text-gray-600 hover:text-primary transition-colors"
        >Problema</a
      >
      <a
        href="#sobre"
        class="text-sm font-medium text-gray-600 hover:text-primary transition-colors"
        >Solução</a
      >
      <a
        href="#servicos"
        class="text-sm font-medium text-gray-600 hover:text-primary transition-colors"
        >Serviços</a
      >
      <a
        href="#processo"
        class="text-sm font-medium text-gray-600 hover:text-primary transition-colors"
        >Processo</a
      >
      <a
        href="#estudio"
        class="text-sm font-medium text-gray-600 hover:text-primary transition-colors"
        >Estúdio</a
      >
      <a
        href="#projetos"
        class="text-sm font-medium text-gray-600 hover:text-primary transition-colors"
        >Projetos</a
      >
    </nav>

    <div class="flex items-center gap-4">
      <Button href="#contato" size="sm" class="hidden xl:inline-flex">
        Falar com especialista
      </Button>

      <!-- Mobile Menu Toggle -->
      <button
        id="menu-toggle"
        class="xl:hidden p-2 text-gray-900 hover:bg-gray-100 rounded-lg transition-colors"
        aria-label="Abrir Menu"
      >
        <svg
          id="menu-icon"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 256 256"
          ><path
            fill="currentColor"
            d="M224 128a8 8 0 0 1-8 8H40a8 8 0 0 1 0-16h176a8 8 0 0 1 8 8ZM40 72h176a8 8 0 0 0 0-16H40a8 8 0 0 0 0 16Zm176 112H40a8 8 0 0 0 0 16h176a8 8 0 0 0 0-16Z"
          ></path></svg
        >
        <svg
          id="close-icon"
          class="hidden"
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 256 256"
          ><path
            fill="currentColor"
            d="M205.66 194.34a8 8 0 0 1-11.32 11.32L128 139.31l-66.34 66.35a8 8 0 0 1-11.32-11.32L116.69 128L50.34 61.66a8 8 0 0 1 11.32-11.32L128 116.69l66.34-66.35a8 8 0 0 1 11.32 11.32L139.31 128Z"
          ></path></svg
        >
      </button>
    </div>
  </Container>

  <!-- Mobile Menu Drawer -->
  <div
    id="mobile-menu"
    class="hidden absolute top-full left-0 w-full bg-white border-b border-gray-100 shadow-xl xl:hidden overflow-hidden transition-all duration-300 transform origin-top scale-y-95 opacity-0"
  >
    <nav class="flex flex-col p-6 gap-4">
      <a
        href="#estrutura"
        class="mobile-link text-lg font-medium text-gray-700 hover:text-primary py-2 px-4 rounded-xl hover:bg-gray-50 transition-all"
        >Problema</a
      >
      <a
        href="#sobre"
        class="mobile-link text-lg font-medium text-gray-700 hover:text-primary py-2 px-4 rounded-xl hover:bg-gray-50 transition-all"
        >Solução</a
      >
      <a
        href="#servicos"
        class="mobile-link text-lg font-medium text-gray-700 hover:text-primary py-2 px-4 rounded-xl hover:bg-gray-50 transition-all"
        >Serviços</a
      >
      <a
        href="#processo"
        class="mobile-link text-lg font-medium text-gray-700 hover:text-primary py-2 px-4 rounded-xl hover:bg-gray-50 transition-all"
        >Processo</a
      >
      <a
        href="#estudio"
        class="mobile-link text-lg font-medium text-gray-700 hover:text-primary py-2 px-4 rounded-xl hover:bg-gray-50 transition-all"
        >Estúdio</a
      >
      <a
        href="#projetos"
        class="mobile-link text-lg font-medium text-gray-700 hover:text-primary py-2 px-4 rounded-xl hover:bg-gray-50 transition-all"
        >Projetos</a
      >
      <hr class="border-gray-100 my-2" />
      <Button href="#contato" class="w-full">Falar com especialista</Button>
    </nav>
  </div>
</header>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");
  const mobileLinks = document.querySelectorAll(".mobile-link");
  const header = document.getElementById("main-header");

  function toggleMenu() {
    if (!mobileMenu || !menuIcon || !closeIcon) return;

    const isHidden = mobileMenu.classList.contains("hidden");

    if (isHidden) {
      mobileMenu.classList.remove("hidden");
      // Force reflow
      void mobileMenu.offsetWidth;
      mobileMenu.classList.add("scale-y-100", "opacity-100");
      mobileMenu.classList.remove("scale-y-95", "opacity-0");
      menuIcon.classList.add("hidden");
      closeIcon.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    } else {
      mobileMenu.classList.remove("scale-y-100", "opacity-100");
      mobileMenu.classList.add("scale-y-95", "opacity-0");
      menuIcon.classList.remove("hidden");
      closeIcon.classList.add("hidden");
      document.body.style.overflow = "";
      setTimeout(() => {
        mobileMenu.classList.add("hidden");
      }, 300);
    }
  }

  menuToggle?.addEventListener("click", toggleMenu);

  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (mobileMenu && !mobileMenu.classList.contains("hidden")) {
        toggleMenu();
      }
    });
  });

  // Header scroll effect
  window.addEventListener("scroll", () => {
    if (!header) return;
    if (window.scrollY > 20) {
      header.classList.add("py-2", "shadow-md");
      header.classList.remove("py-4");
    } else {
      header.classList.remove("py-2", "shadow-md");
      header.classList.add("py-4");
    }
  });
</script>
